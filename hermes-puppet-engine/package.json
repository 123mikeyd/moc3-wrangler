{
  "name": "hermes-puppet-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source 2D puppet animation engine — replace Live2D",
  "scripts": {
    "build": "esbuild src/engine.ts --bundle --outfile=dist/engine.js --format=esm --platform=browser --sourcemap",
    "dev": "esbuild src/engine.ts --bundle --outfile=dist/engine.js --format=esm --platform=browser --sourcemap --watch"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "ag-psd": "^30.1.1",
    "three": "^0.170.0"
  }
}
