{
  "compilerOptions": {
    "target": "es2020",
    "module": "es2020",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": false,
    "sourceMap": true,
    "typeRoots": ["./lib/Core", "./node_modules/@types"]
  },
  "include": [
    "src/**/*.ts",
    "lib/Core/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "lib/CubismWebFramework"
  ]
}
